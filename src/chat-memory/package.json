{
  "name": "chat-memory",
  "version": "1.0.0",
  "main": "src/index.ts",
  "description": "Projeto responsável por criar uma conversao sobre negocios",
  "scripts": {
    "lint": "biome check --write src/",
    "dev": "nodemon",
    "start": "ts-node src/index.ts",
    "release": "standard-version",
    "test:ci": "vitest run",
    "test:local": "vitest run --reporter=verbose",
    "test:watch": "vitest"
  },
  "author": "Jeison O. da Silva <jeison.desenvolvimento@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/blessed": "^0.1.27",
    "@types/node": "^25.9.1",
    "dotenv": "^17.4.2",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "nodemonConfig": {
    "watch": [
      ".env",
      "src"
    ],
    "ext": "ts",
    "ignore": [
      "src/**/*.test.ts"
    ],
    "exec": "npx ts-node -r dotenv/config ./src/index"
  },
  "dependencies": {
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/openai": "^1.4.7",
    "zod": "^4.4.3"
  }
}
